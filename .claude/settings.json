{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ssh *)",
      "Bash(curl *)",
      "Bash(docker *)",
      "Bash(mosquitto_pub *)",
      "Bash(mosquitto_sub *)",
      "Bash(psql *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(awk *)",
      "Bash(ping *)",
      "Bash(dig *)",
      "Bash(nslookup *)",
      "Bash(nvidia-smi *)",
      "Bash(git *)",
      "Bash(echo *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm -rf /)*",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP TABLE*)",
      "Bash(*TRUNCATE*)",
      "Bash(reboot)*",
      "Bash(shutdown)*",
      "Bash(poweroff)*",
      "Bash(docker system prune*)",
      "Bash(docker volume prune*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/safety-check.sh"
          }
        ]
      }
    ]
  }
}
