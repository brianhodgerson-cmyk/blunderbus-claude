# BlunderBus - Environment Variables
# Copy to .env and fill in real values.
# Never commit the .env file.
# Optional: populate .env from Vaultwarden via Bitwarden CLI:
#   PowerShell: .\scripts\fill-env-from-bitwarden.ps1 -Force

# === Local Runtime / Vault bootstrap ===
# Needed by the Windows runner scripts and still useful on ProfX until everything
# is systemd/cron-native.
BW_MASTER_PASS=your_bitwarden_master_password
TELEGRAM_ALLOWED_USER_IDS=123456789
OBSIDIAN_URL=https://127.0.0.1:27124
BLUNDERBUS_NOTE_BACKEND=filesystem
BLUNDERBUS_VAULT_ROOT=
BLUNDERBUS_CLICKHOUSE_DATABASE=blunderbus
BLUNDERBUS_HISTORY_BACKEND=memory
REDIS_URL=

# === SSH ===
# Use SSH public key auth only.
# Recommended: store the private key in Vaultwarden and expose it through
# Bitwarden Desktop's SSH Agent on this machine.
# On Windows, Bitwarden's SSH agent expects the OpenSSH Authentication Agent
# service to be disabled.
# Then install the host aliases from .ssh-config.example into ~/.ssh/config:
#   PowerShell: .\scripts\install-ssh-config.ps1

# === Home Assistant ===
HA_LONG_LIVED_TOKEN=your_ha_long_lived_access_token
HA_URL=http://192.168.50.206:8123

# === pfSense ===
PFSENSE_USER=admin
PFSENSE_PASS=your_pfsense_password

# === Security Onion Connect (read only) ===
# Use a Security Onion API Client from SOC Administration -> API Clients.
# The SOC web UI username/password does not work for Connect API calls.
SECONION_URL=https://soc.hodgespot.com
SECONION_CLIENT_ID=your_seconion_client_id
SECONION_CLIENT_SECRET=your_seconion_client_secret
# Optional: only set this if your grid requires a non-default OAuth scope.
SECONION_TOKEN_SCOPE=

# === TrueNAS ===
TRUENAS_API_KEY=your_truenas_api_key

# === Grafana ===
GRAFANA_TOKEN=your_grafana_api_key
# Legacy alias still accepted by some scripts during migration:
# GRAFANA_API_KEY=your_grafana_api_key

# === Threat Intelligence ===
VIRUSTOTAL_API_KEY=your_virustotal_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
SHODAN_API_KEY=your_shodan_api_key

# === MQTT (Mosquitto on Stark) ===
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password

# === Vaultwarden ===
VAULTWARDEN_ADMIN_TOKEN=your_vaultwarden_admin_token

# === AdGuard Home ===
ADGUARD_USER=admin
ADGUARD_PASS=your_adguard_password
ADGUARD_HOST=192.168.50.53:80

# === Portainer (Stark) ===
PORTAINER_USER=admin
PORTAINER_PASS=your_portainer_password

# === Nginx Proxy Manager (Stark) ===
NPM_USER=admin@example.com
NPM_PASS=your_npm_password

# === Clickhouse (Cortex) ===
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password
# Legacy alias still accepted by some scripts during migration:
# CLICKHOUSE_PASS=your_clickhouse_password

# === LiteLLM (Cortex) ===
LITELLM_API_KEY=your_litellm_api_key
LITELLM_MASTER_KEY=your_litellm_master_key

# === Loki ===
LOKI_URL=http://192.168.50.207:3100

# === Google Calendar / Tasks ===
GOOGLE_CALENDAR_TOKEN=
GOOGLE_TASKS_TOKEN=

# === Google Fit ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === InfluxDB (Banner health dashboards) ===
INFLUXDB_URL=http://192.168.50.202:8086
INFLUXDB_ORG=blunderbus
INFLUXDB_BUCKET=samsung_health
INFLUXDB_TOKEN=

# === Monarch Money login bootstrap ===
MONARCH_USER=
MONARCH_PASS=
