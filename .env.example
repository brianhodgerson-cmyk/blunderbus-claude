# BlunderBus — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit the .env file.

# === SSH ===
# Ensure SSH key auth is configured for all VMs.
# ssh-copy-id user@<IP> for each host.

# === Home Assistant ===
HA_LONG_LIVED_TOKEN=your_ha_long_lived_access_token
HA_URL=http://192.168.50.206:8123

# === pfSense ===
PFSENSE_USER=admin
PFSENSE_PASS=your_pfsense_password

# === Security Onion (READ-ONLY) ===
SECONION_API_KEY=your_seconion_api_key

# === TrueNAS ===
TRUENAS_API_KEY=your_truenas_api_key

# === Grafana ===
GRAFANA_API_KEY=your_grafana_api_key

# === Threat Intelligence ===
VIRUSTOTAL_API_KEY=your_virustotal_api_key
ABUSEIPDB_API_KEY=your_abuseipdb_api_key
SHODAN_API_KEY=your_shodan_api_key

# === MQTT (Mosquitto on Stark) ===
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password

# === Vaultwarden ===
VAULTWARDEN_ADMIN_TOKEN=your_vaultwarden_admin_token

# === AdGuard Home ===
ADGUARD_USER=admin
ADGUARD_PASS=your_adguard_password
ADGUARD_HOST=192.168.50.x:3000

# === Portainer (Stark) ===
PORTAINER_USER=admin
PORTAINER_PASS=your_portainer_password

# === Nginx Proxy Manager (Stark) ===
NPM_USER=admin@example.com
NPM_PASS=your_npm_password

# === Clickhouse (Cortex) ===
CLICKHOUSE_USER=default
CLICKHOUSE_PASS=your_clickhouse_password

# === LiteLLM (Cortex) ===
LITELLM_API_KEY=your_litellm_api_key
LITELLM_MASTER_KEY=your_litellm_master_key

# === Loki ===
LOKI_URL=http://192.168.50.207:3100
