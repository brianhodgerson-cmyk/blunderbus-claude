[Unit]
Description=BlunderBus failure diagnosis for %i
Documentation=file:/home/brian/blunderbus-claude/scripts/failure_agent.py
# Deliberately NO OnFailure= here — the failure handler must never storm itself.

[Service]
Type=oneshot
WorkingDirectory=/home/brian/blunderbus-claude
Environment=PATH=/home/brian/blunderbus-claude/.venv/bin:/home/brian/.hermes/node/bin:/home/brian/.local/bin:/home/brian/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin
ExecStart=/home/brian/blunderbus-claude/scripts/run_pipeline.sh failure_agent.py %i
Nice=10
StandardOutput=append:/home/brian/blunderbus-claude/logs/systemd-failure-agent.log
StandardError=append:/home/brian/blunderbus-claude/logs/systemd-failure-agent.log
